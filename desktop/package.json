{
  "name": "rog-terminal-desktop",
  "version": "1.0.0",
  "description": "Rog Terminal Desktop - Cross-platform collaborative MCP client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux"
  },
  "build": {
    "appId": "com.rogtech.rog-terminal",
    "productName": "Rog Terminal",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "tray-icon.png"
    ],
    "extraResources": [
      {
        "from": "../frontend/build",
        "to": "frontend",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "../frontend/public/icons/icon-512.svg"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "../frontend/public/icons/icon-512.svg",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "../frontend/public/icons/icon-512.svg",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["en_US"],
      "shortcutName": "Rog Terminal"
    }
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
